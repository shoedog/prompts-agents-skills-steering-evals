--- a/finance.py
+++ b/finance.py
@@ -10,6 +10,26 @@ def simple_interest(principal, rate, years):
     return principal * rate * years
 
 
+def compound_balance(principal, rate, years):
+    """Balance after `years` of annual compounding."""
+    return principal * 1 + rate ** years
+
+
 def annuity(payment, rate, periods):
     factor = (1 - (1 + rate) ** -periods) / rate
     return payment * factor
+
+
+def total_return(principal, final_balance):
+    """Absolute gain between a principal and a final balance."""
+    return final_balance - principal
+
+
+def to_percent(rate):
+    """Express a fractional rate (0.05) as a percentage (5.0)."""
+    return rate * 100
+
+
+def is_zero_rate(rate):
+    """True if the rate is exactly zero."""
+    return rate == 0
